{
  "name": "20-20-20-break-reminder",
  "version": "1.0.5",
  "description": "Desktop reminder app for the 20-20-20 eye break rule.",
  "author": "Micheal-nn",
  "license": "MIT",
  "main": "src/main.js",
  "repository": {
    "type": "git",
    "url": "git@github.com:Micheal-nn/20-20-20-reminder.git"
  },
  "homepage": "https://github.com/Micheal-nn/20-20-20-reminder",
  "scripts": {
    "check:env": "node scripts/check-env.js",
    "setup:env": "node scripts/check-env.js --fix",
    "start": "electron .",
    "build:mac:x64": "electron-builder --mac dmg zip --x64",
    "build:mac:arm64": "electron-builder --mac dmg zip --arm64",
    "build:win:x64": "electron-builder --win portable nsis --x64",
    "build:win:arm64": "electron-builder --win portable nsis --arm64",
    "build:linux:x64": "electron-builder --linux AppImage --x64",
    "build:linux:arm64": "electron-builder --linux AppImage --arm64",
    "build:mac": "npm run build:mac:x64",
    "build:win": "npm run build:win:x64",
    "build:linux": "npm run build:linux:x64"
  },
  "build": {
    "appId": "com.codex.twentytwentytwentyreminder",
    "productName": "20-20-20 Reminder",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "outputs/build"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ]
    },
    "portable": {
      "artifactName": "${productName}-${version}-${os}-${arch}-portable.${ext}"
    },
    "nsis": {
      "artifactName": "${productName}-${version}-${os}-${arch}-setup.${ext}"
    },
    "mac": {
      "category": "public.app-category.healthcare-fitness",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
